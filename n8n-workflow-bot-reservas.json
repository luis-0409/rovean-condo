    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "=✅ *Reserva Confirmada!*\n\nOlá, {{ $('Identificar Morador').item.json.data.nome }}!\n\nSua reserva foi registrada com sucesso.\n\n📍 Área: {{ $('Extrair Dados Reserva').item.json.area }}\n📅 Data: {{ new Date($('Extrair Dados Reserva').item.json.data + 'T12:00:00').toLocaleDateString('pt-BR') }}\n🕐 Horário: {{ $('Extrair Dados Reserva').item.json.horarioInicio }} às {{ $('Extrair Dados Reserva').item.json.horarioFim }}\n\nQualquer dúvida, entre em contato com a portaria. 🏢",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
