        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ telegramId: $('Telegram Trigger').item.json.message.from.id.toString(), area: $('Extrair Dados Reserva').item.json.area, data: $('Extrair Dados Reserva').item.json.data, horarioInicio: $('Extrair Dados Reserva').item.json.horarioInicio, horarioFim: $('Extrair Dados Reserva').item.json.horarioFim }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000013",
      "name": "Criar Reserva",
      "type": "n8n-nodes-base.httpRequest",
