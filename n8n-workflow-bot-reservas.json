    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "=❌ *Horário Indisponível*\n\nInfelizmente a *{{ $('Extrair Dados Reserva').item.json.area }}* já está reservada no dia {{ new Date($('Extrair Dados Reserva').item.json.data + 'T12:00:00').toLocaleDateString('pt-BR') }} nesse horário.\n\nTente outro horário ou outra data. 📅",
        "additionalFields": {
